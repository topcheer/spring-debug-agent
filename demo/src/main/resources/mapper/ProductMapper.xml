<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
   "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.mybatis.ProductMapper">

    <resultMap id="productMap" type="com.demo.mybatis.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="category" column="category"/>
        <result property="price" column="price"/>
        <result property="description" column="description"/>
    </resultMap>

    <insert id="insertProduct" parameterType="com.demo.mybatis.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mybatis_product (name, category, price, description)
        VALUES (#{name}, #{category}, #{price}, #{description})
    </insert>

    <select id="searchProducts" resultMap="productMap">
        SELECT * FROM mybatis_product
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="minPrice != null">
                AND price &gt;= #{minPrice}
            </if>
            <if test="maxPrice != null">
                AND price &lt;= #{maxPrice}
            </if>
        </where>
        ORDER BY price DESC
    </select>

    <cache eviction="LRU" flushInterval="60000" size="512" readOnly="true"/>

</mapper>
